rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if user is document owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      return isAuth() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
        (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role != 'admin') &&
        (!request.resource.data.keys().hasAll(['verified']) || request.resource.data.verified == false) &&
        (!request.resource.data.keys().hasAll(['kycStatus']) || request.resource.data.kycStatus == 'Pending' || request.resource.data.kycStatus == null);
      allow update: if isAdmin() || (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'verified', 'kycStatus'])));
      allow delete: if isAdmin();
    }

    // Notifications Rules
    match /notifications/{notificationId} {
      allow read, update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Properties Rules (stored in SQL Connect, legacy path restricted)
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Saved Searches Rules
    match /savedSearches/{searchId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Offers Rules
    match /offers/{offerId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && 
        request.resource.data.userId == request.auth.uid &&
        (!request.resource.data.keys().hasAll(['status']) || request.resource.data.status == 'Submitted');
      allow update, delete: if isAdmin();
    }

    // Escrows Rules
    match /escrows/{escrowId} {
      allow read: if isAuth() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Escrows are created by Admin upon accepting an offer
      allow update: if isAuth() && (
        isAdmin() || (
          resource.data.buyerId == request.auth.uid &&
          // Buyer can only update their escrow under strict conditions based on the current stage:
          (
            // Stage 1: Buyer submitting payment verification
            (resource.data.stage == 1 && 
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentBank', 'paymentRef', 'paymentReceiptUrl', 'paymentSubmittedAt', 'updatedAt']) &&
             request.resource.data.paymentStatus == 'Pending Verification') ||
            
            // Stage 2: Buyer signing/executing Deed of Assignment
            (resource.data.stage == 2 && 
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deedStatus', 'deedUrl', 'signatureUrl', 'deedUploadedAt', 'updatedAt']) &&
             request.resource.data.deedStatus == 'Pending Verification') ||
            
            // Stage 3: Buyer taking possession & releasing funds
            (resource.data.stage == 3 && 
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stage', 'status', 'fundsReleased', 'updatedAt']) &&
             request.resource.data.stage == 4 &&
             request.resource.data.status == 'Completed' &&
             request.resource.data.fundsReleased == true)
          )
        )
      );
      allow delete: if isAdmin();
    }

    // Activity Logs Rules
    match /activity_logs/{logId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Inspection Requests Rules
    match /inspection_requests/{requestId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
